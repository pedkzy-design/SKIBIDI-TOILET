----------------------------------------------------------------
-- BALL PREDICTION
----------------------------------------------------------------

local STEPS     = 80
local STEP_SIZE = 0.05
local GRAVITY   = Vector3.new(0, -workspace.Gravity, 0)
local BALL_RADIUS = 1.5

local predEnabled  = false
local beamColor    = ColorSequence.new(Color3.fromRGB(255, 100, 0), Color3.fromRGB(255, 255, 0))
local beamWidth0   = 0.15
local beamWidth1   = 0.05
local bounceColor  = Color3.fromRGB(0, 200, 255)
local bounceSize   = Vector3.new(1.5, 1.5, 1.5)
local bounceTransp = 0.5

local beamFolder = Instance.new("Folder")
beamFolder.Name  = "BallPredictions"
beamFolder.Parent = workspace

local ballData = {}

local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Exclude

local function getBallsFolder()
    return workspace:FindFirstChild("Debris")
        and workspace.Debris:FindFirstChild("Balls")
end

local function createIndicatorBall()
    local part = Instance.new("Part")
    part.Size         = bounceSize
    part.Color        = bounceColor
    part.Transparency = 1
    part.Anchored     = true
    part.CanCollide   = false
    part.CanQuery     = false
    part.CastShadow   = false
    part.Material     = Enum.Material.Neon
    part.Parent       = beamFolder
    local mesh = Instance.new("SpecialMesh")
    mesh.MeshType = Enum.MeshType.Sphere
    mesh.Parent   = part
    return part
end

local function createDataForBall(ball)
    local data = {}
    local attachments = {}
    for i = 1, STEPS do
        local att = Instance.new("Attachment")
        att.Parent = workspace.Terrain
        attachments[i] = att
    end
    local beams = {}
    for i = 1, STEPS - 1 do
        local beam = Instance.new("Beam")
        beam.Attachment0 = attachments[i]
        beam.Attachment1 = attachments[i + 1]
        beam.Color       = beamColor
        beam.Width0      = beamWidth0
        beam.Width1      = beamWidth1
        beam.FaceCamera  = true
        beam.Segments    = 1
        beam.Parent      = beamFolder
        beams[i] = beam
    end
    data.attachments = attachments
    data.beams       = beams
    data.ballBounce  = createIndicatorBall()
    data.connection  = ball.AncestryChanged:Connect(function()
        if not ball:IsDescendantOf(workspace) then
            if ballData[ball] then
                for _, att  in ipairs(ballData[ball].attachments) do att:Destroy()  end
                for _, beam in ipairs(ballData[ball].beams)       do beam:Destroy() end
                ballData[ball].ballBounce:Destroy()
                ballData[ball].connection:Disconnect()
                ballData[ball] = nil
            end
        end
    end)
    return data
end

local function cleanAll()
    for ball, data in pairs(ballData) do
        for _, att  in ipairs(data.attachments) do att:Destroy()  end
        for _, beam in ipairs(data.beams)       do beam:Destroy() end
        data.ballBounce:Destroy()
        data.connection:Disconnect()
        ballData[ball] = nil
    end
end

local function simulateTrajectory(ball)
    local weight   = ball:FindFirstChild("Weight")
    local friction = ball:FindFirstChild("Friction")
    local extraForce = Vector3.new(0, 0, 0)
    if weight   and weight:IsA("BodyForce")   then extraForce += weight.Force   end
    if friction and friction:IsA("BodyForce") then extraForce += friction.Force end
    local mass = ball.AssemblyMass
    if mass == 0 then mass = 1 end
    local acceleration = GRAVITY + (extraForce / mass)
    local points      = {}
    local pos         = ball.Position
    local vel         = ball.AssemblyLinearVelocity
    local bouncePoint = nil
    for i = 1, STEPS do
        points[i] = pos
        local nextVel = vel + acceleration * STEP_SIZE
        local nextPos = pos + nextVel * STEP_SIZE
        if not bouncePoint then
            local dir    = nextPos - pos
            local result = workspace:Raycast(pos, dir * (1 + BALL_RADIUS / dir.Magnitude), raycastParams)
            if result then
                bouncePoint = result.Position + result.Normal * BALL_RADIUS
            end
        end
        vel = nextVel
        pos = nextPos
    end
    return points, bouncePoint
end

local function updatePredictions()
    if not predEnabled then return end
    local ballsFolder = getBallsFolder()
    if not ballsFolder then return end
    local allBalls = ballsFolder:GetChildren()
    table.insert(allBalls, beamFolder)
    raycastParams.FilterDescendantsInstances = allBalls
    for _, ball in ipairs(ballsFolder:GetChildren()) do
        if ball:IsA("BasePart") then
            if not ballData[ball] then
                ballData[ball] = createDataForBall(ball)
            end
            local data = ballData[ball]
            local points, bouncePoint = simulateTrajectory(ball)
            for _, beam in ipairs(data.beams) do
                beam.Color  = beamColor
                beam.Width0 = beamWidth0
                beam.Width1 = beamWidth1
            end
            for i, point in ipairs(points) do
                data.attachments[i].WorldPosition = point
            end
            data.ballBounce.Color = bounceColor
            data.ballBounce.Size  = bounceSize
            if bouncePoint then
                data.ballBounce.Position     = bouncePoint
                data.ballBounce.Transparency = bounceTransp
            else
                data.ballBounce.Transparency = 1
            end
        end
    end
end

RunService.RenderStepped:Connect(updatePredictions)

