----------------------------------------------------------------

local function ApplyLeg()
    local char = GetChar()
    local rLeg = char:FindFirstChild("Right Leg")
    local lLeg = char:FindFirstChild("Left Leg")
    if not rLeg or not lLeg then return end

    for _, leg in pairs({rLeg, lLeg}) do
        if legTransparent then
            -- Remove mesh, aplica transparência e cor
            if leg:FindFirstChild("SAML_Mesh") then leg.SAML_Mesh:Destroy() end
            leg.Transparency = 0.5
            leg.Color = legColor
        else
            -- Aplica mesh
            local mesh = leg:FindFirstChild("SAML_Mesh") or Instance.new("SpecialMesh", leg)
            mesh.Name = "SAML_Mesh"
            mesh.MeshId = v_legMeshID
            mesh.Scale = Vector3.new(1, 1, 1)
            leg.Transparency = 0
            leg.Color = legColor
        end
        leg.Size = Vector3.new(legSize, 2, legSize)
    end
end

local function ResetLeg()
    local char = GetChar()
    local rLeg = char:FindFirstChild("Right Leg")
    local lLeg = char:FindFirstChild("Left Leg")
    if not rLeg or not lLeg then return end
    for _, leg in pairs({rLeg, lLeg}) do
        if leg:FindFirstChild("SAML_Mesh") then leg.SAML_Mesh:Destroy() end
        leg.Size = Vector3.new(1, 2, 1)
        leg.Transparency = 0
        leg.Color = Color3.fromRGB(163, 162, 165)
    end
end

local function ApplyArm()
    local char = GetChar()
    local rArm = char:FindFirstChild("Right Arm")
    local lArm = char:FindFirstChild("Left Arm")
    if not rArm or not lArm then return end

    for _, arm in pairs({rArm, lArm}) do
        if armTransparent then
            if arm:FindFirstChild("SAML_ArmMesh") then arm.SAML_ArmMesh:Destroy() end
            arm.Transparency = 0.5
            arm.Color = armColor
        else
            local mesh = arm:FindFirstChild("SAML_ArmMesh") or Instance.new("SpecialMesh", arm)
            mesh.Name = "SAML_ArmMesh"
            mesh.MeshId = "rbxassetid://113784110775765"
            arm.Transparency = 0
            arm.Color = armColor
        end
        arm.Size = Vector3.new(armSize * 2, armSize * 2, armSize)
    end
end

local function ResetArm()
    local char = GetChar()
    local rArm = char:FindFirstChild("Right Arm")
    local lArm = char:FindFirstChild("Left Arm")
    if not rArm or not lArm then return end
    for _, arm in pairs({rArm, lArm}) do
        if arm:FindFirstChild("SAML_ArmMesh") then arm.SAML_ArmMesh:Destroy() end
        arm.Size = Vector3.new(1, 2, 1)
        arm.Transparency = 0
        arm.Color = Color3.fromRGB(163, 162, 165)
    end
end

local function ApplyHead()
    local char = GetChar()
    local head = char:FindFirstChild("Head")
    if not head then return end

    if headTransparent then
        local m = head:FindFirstChildOfClass("SpecialMesh")
        if m then m.Scale = Vector3.new(0.001, 0.001, 0.001) end
        head.Transparency = 0.5
        head.Color = headColor
    else
        head.Transparency = 0
        head.Color = headColor
        local m = head:FindFirstChildOfClass("SpecialMesh")
        if m then m.Scale = v_headMeshScale end
    end
    head.Size = Vector3.new(headSize, headSize * 0.5, headSize * 0.5)
    head.CanCollide = false
end

local function ResetHead()
    local char = GetChar()
    local head = char:FindFirstChild("Head")
    if not head then return end
    head.Size = Vector3.new(2, 1, 1)
    head.CanCollide = true
    head.Transparency = 0
    head.Color = Color3.fromRGB(163, 162, 165)
    local m = head:FindFirstChildOfClass("SpecialMesh")
    if m then m.Scale = Vector3.new(1.25, 1.25, 1.25) end
end

