local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local Window = Rayfield:CreateWindow({
	Name = "SAML HUB",
	LoadingTitle = "CARREGANDO...",
	LoadingSubtitle = "by SAMLLEAKS",
	ConfigurationSaving = {
		Enabled = true,
		FileName = "Big Hub"
	},
})

-- VARIÁVEIS
local LegScale, ArmScale, HeadScale = 1,1,1
local LegColorMode, ArmColorMode, HeadColorMode = false,false,false

local LegColor = Color3.fromRGB(0,0,0)
local ArmColor = Color3.fromRGB(0,0,0)
local HeadColor = Color3.fromRGB(0,0,0)

local LegTransparency, ArmTransparency, HeadTransparency = 0,0,0

local v_legSize = Vector3.new(1.6,2,1.4)
local v_legMeshID = "rbxassetid://109302786609504"

local Tab = Window:CreateTab("Main")
local ArmsTab = Window:CreateTab("Arms")
local LegTab = Window:CreateTab("Legs")
local HeadTab = Window:CreateTab("Head")

local function GetChar()
	return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

--------------------------------------------------
-- LEGS
--------------------------------------------------
local LegToggle = LegTab:CreateToggle({
	Name = "BIGFOOT",
	CurrentValue = false,
	Callback = function(Value)
		local char = GetChar()
		local rLeg = char:FindFirstChild("Right Leg")
		local lLeg = char:FindFirstChild("Left Leg")
		if not rLeg or not lLeg then return end

		for _, leg in pairs({rLeg, lLeg}) do
			if Value then
				if LegColorMode then
					if leg:FindFirstChild("Mesh") then
						leg.Mesh:Destroy()
					end
					leg.Color = LegColor
					leg.Transparency = LegTransparency
				else
					local mesh = Instance.new("SpecialMesh", leg)
					mesh.MeshId = v_legMeshID
					leg.Color = Color3.new(1,1,1)
					leg.Transparency = 0
				end

				leg.Size = v_legSize * LegScale
			else
				for _,v in pairs(leg:GetChildren()) do
					if v:IsA("SpecialMesh") then v:Destroy() end
				end
				leg.Size = Vector3.new(1,2,1)
				leg.Transparency = 0
			end
		end
	end,
})

LegTab:CreateSlider({
	Name = "Leg Size",
	Range = {1,5},
	Increment = 0.1,
	CurrentValue = 1,
	Callback = function(v)
		LegScale = v
	end,
})

LegTab:CreateToggle({
	Name = "Leg Color Mode",
	CurrentValue = false,
	Callback = function(v)
		LegColorMode = v
	end,
})

LegTab:CreateColorPicker({
	Name = "Leg Color",
	Color = LegColor,
	Callback = function(v)
		LegColor = v
	end,
})

LegTab:CreateSlider({
	Name = "Leg Transparency",
	Range = {0,1},
	Increment = 0.05,
	CurrentValue = 0,
	Callback = function(v)
		LegTransparency = v
	end,
})

