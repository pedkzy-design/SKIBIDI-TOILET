local function GetChar()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function sanitizeID(id)
    if id == "" or id == nil then return nil end
    if id:match("^rbxassetid://") then return id end
    if id:match("^%d+$") then return "rbxassetid://" .. id end
    return nil
end

----------------------------------------------------------------
-- LEGS
----------------------------------------------------------------

local function ApplyLeg()
    local char = GetChar()
    local rLeg = char:FindFirstChild("Right Leg")
    local lLeg = char:FindFirstChild("Left Leg")
    if not rLeg or not lLeg then return end

    for _, leg in pairs({rLeg, lLeg}) do
        if legTransparent then
            if leg:FindFirstChild("SAML_Mesh") then leg.SAML_Mesh:Destroy() end
            leg.Transparency = 0.5
            leg.Color = legColor
        else
            local mesh = leg:FindFirstChild("SAML_Mesh") or Instance.new("SpecialMesh", leg)
            mesh.Name = "SAML_Mesh"
            local meshID    = sanitizeID(legCustomMeshID)
            local texID     = sanitizeID(legCustomTextureID)
            mesh.MeshId     = meshID    or v_legMeshID
            mesh.TextureId  = texID     or ""
            mesh.Scale      = Vector3.new(1, 1, 1)
            leg.Transparency = 0
            leg.Color = legColor
        end
        leg.Size = Vector3.new(legSize, 2, legSize)
    end
end

local function ResetLeg()
    local char = GetChar()
    local rLeg = char:FindFirstChild("Right Leg")
    local lLeg = char:FindFirstChild("Left Leg")
    if not rLeg or not lLeg then return end
    for _, leg in pairs({rLeg, lLeg}) do
        if leg:FindFirstChild("SAML_Mesh") then leg.SAML_Mesh:Destroy() end
        leg.Size = Vector3.new(1, 2, 1)
        leg.Transparency = 0
        leg.Color = Color3.fromRGB(163, 162, 165)
    end
end

