----------------------------------------------------------------
-- BALL PREDICTION
----------------------------------------------------------------

local BallPredictionEnabled = false
local BallPredColor = Color3.fromRGB(255, 255, 255)
local BallPredSize = 0.1
local BallPredAccuracy = 5
local BallPredRefresh = 0.1
local BallPredThreshold = 25
local BallPredDump = {}

local function quadraticSolver(a, b, c)
    local x1 = (-b + math.sqrt(b * b - 4 * a * c)) / (2 * a)
    local x2 = (-b - math.sqrt(b * b - 4 * a * c)) / (2 * a)
    return (x2 > x1 and x2 or x1)
end

local function findLandingPosition(vel, pos, acc, accu)
    local t = quadraticSolver(0.5 * -acc, vel.Y, pos.Y)
    return pos + Vector3.new(vel.X * t, -acc * (t * t) / 2 + vel.Y * t, vel.Z * t)
end

BallTab:CreateToggle({ Name = "BALL PREDICTION", CurrentValue = false, Callback = function(v) BallPredictionEnabled = v end })
BallTab:CreateColorPicker({ Name = "Ball Prediction Color", Color = BallPredColor, Callback = function(v) BallPredColor = v end })
BallTab:CreateSlider({ Name = "Trail Size", Range = {0.01, 0.5}, Increment = 0.01, CurrentValue = 0.1, Callback = function(v) BallPredSize = v end })
BallTab:CreateSlider({ Name = "Prediction Accuracy", Range = {1, 10}, Increment = 1, CurrentValue = 5, Callback = function(v) BallPredAccuracy = v end })
BallTab:CreateSlider({ Name = "Refresh Rate", Range = {0.05, 1}, Increment = 0.05, CurrentValue = 0.1, Callback = function(v) BallPredRefresh = v end })
BallTab:CreateSlider({ Name = "Velocity Threshold", Range = {0, 100}, Increment = 1, CurrentValue = 25, Callback = function(v) BallPredThreshold = v end })

task.spawn(function()
    while true do
        task.wait(BallPredRefresh)
        for _, i in pairs(BallPredDump) do if i then i:Destroy() end end
        table.clear(BallPredDump)
        if not BallPredictionEnabled then continue end
        local BallsFolder = workspace:WaitForChild("Debris"):WaitForChild("Balls")
        for _, obj in pairs(BallsFolder:GetChildren()) do
            if obj:IsA("BasePart") and obj.AssemblyLinearVelocity.Magnitude > BallPredThreshold then
                local land = findLandingPosition(obj.AssemblyLinearVelocity, obj.Position, workspace.Gravity, BallPredAccuracy)
                local a0 = Instance.new("Attachment", workspace.Terrain)
                a0.WorldPosition = obj.Position
                local a1 = Instance.new("Attachment", workspace.Terrain)
                a1.WorldPosition = land
                local beam = Instance.new("Beam")
                beam.Attachment0 = a0
                beam.Attachment1 = a1
                beam.Width0 = BallPredSize
                beam.Width1 = BallPredSize
                beam.FaceCamera = true
                beam.Color = ColorSequence.new(BallPredColor)
                beam.Parent = obj
                table.insert(BallPredDump, a0)
                table.insert(BallPredDump, a1)
                table.insert(BallPredDump, beam)
            end
        end
    end
end)

