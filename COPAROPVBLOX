-- [SISTEMA] BYPASS & SPOOFER INTEGRADO (SAML LEAKS)
----------------------------------------------------------------
local PlayerUpdate = ReplicatedStorage:WaitForChild("PlayerUpdate")
local currentLifeId = 0

-- Função para limpar o lixo do Anti-Cheat e manter a conexão viva
local function applyBypass(char)
    currentLifeId = currentLifeId + 1
    local myLifeId = currentLifeId
    task.wait(0.5) 

    -- 1. Deleta os Scripts (Opaaa e genéricos)
    local function removeScripts()
        for _, child in pairs(char:GetChildren()) do
            if child:IsA("LocalScript") and (child.Name == "LocalScript" or child.Name == "Opaaa") then
                child:Destroy()
                warn("SAML HUB: Script de monitoramento removido!")
            end
        end
    end
    
    removeScripts()

    -- 2. Emulação de Sinal (Heartbeat Spoofing)
    -- Isso engana o servidor para ele achar que o script deletado ainda funciona
    task.spawn(function()
        local lastHeartbeat = 0
        while char == LocalPlayer.Character and char:IsDescendantOf(game) and currentLifeId == myLifeId do
            local now = os.clock()
            if now - lastHeartbeat >= 3 then -- Intervalo de 3s do original
                lastHeartbeat = now
                PlayerUpdate:FireServer("EstouVivo")
            end
            task.wait(1)
        end
    end)
end

-- Hook para interceptar tentativas de detecção de tamanho
-- Se o jogo tentar enviar "TamanhoAlterado", nós bloqueamos aqui.
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if self == PlayerUpdate and method == "FireServer" and args[1] == "TamanhoAlterado" then
        warn("SAML HUB: Tentativa de detecção de Hitbox bloqueada!")
        return nil
    end
    
    return oldNamecall(self, ...)
end)

-- Conexões de Spawn
LocalPlayer.CharacterAdded:Connect(applyBypass)
if LocalPlayer.Character then task.spawn(applyBypass, LocalPlayer.Character) end

