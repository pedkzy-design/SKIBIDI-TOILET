-- BALL PREDICTION (FÍSICA)
----------------------------------------------------------------
local BallPredictionEnabled = false
local BallPredColor = Color3.fromRGB(255,255,255)
local BallPredSize = 0.1
local BallPredAccuracy = 5
local BallPredRefresh = 0.1
local BallPredThreshold = 25
local BallPredDump = {}

local function findLandingPosition(vel,pos,acc)
	local t = ((-vel.Y) - math.sqrt(vel.Y^2 - 4*(0.5*-acc)*pos.Y)) / (2*(0.5*-acc))
	return pos + Vector3.new(vel.X*t, 0, vel.Z*t)
end

BallTab:CreateToggle({
	Name = "BALL PREDICTION",
	CurrentValue = false,
	Callback = function(v) BallPredictionEnabled = v end,
})

-- Loop de Renderização da Bola
task.spawn(function()
	while true do
		task.wait(BallPredRefresh)
		for _,i in pairs(BallPredDump) do if i then i:Destroy() end end
		table.clear(BallPredDump)

		if BallPredictionEnabled then
            local Debris = workspace:FindFirstChild("Debris")
            local Balls = Debris and Debris:FindFirstChild("Balls")
            
            if Balls then
                for _,obj in pairs(Balls:GetChildren()) do
                    if obj:IsA("BasePart") and obj.AssemblyLinearVelocity.Magnitude > BallPredThreshold then
                        local land = findLandingPosition(obj.AssemblyLinearVelocity, obj.Position, workspace.Gravity)
                        
                        local a0 = Instance.new("Attachment", workspace.Terrain)
                        a0.WorldPosition = obj.Position
                        local a1 = Instance.new("Attachment", workspace.Terrain)
                        a1.WorldPosition = land

                        local beam = Instance.new("Beam", obj)
                        beam.Attachment0 = a0
                        beam.Attachment1 = a1
                        beam.Width0 = BallPredSize
                        beam.Width1 = BallPredSize
                        beam.Color = ColorSequence.new(BallPredColor)

                        table.insert(BallPredDump, a0)
                        table.insert(BallPredDump, a1)
                        table.insert(BallPredDump, beam)
                    end
                end
            end
		end
	end
end)

